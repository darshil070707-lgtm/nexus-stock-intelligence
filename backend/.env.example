# NEXUS Configuration
# Copy this to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=NEXUS
APP_VERSION=2.0.0
BASE_DIR=/app/backend
MODEL_DIR=/tmp/nexus_models

# ── Database ──────────────────────────────────────────────────────────────
# Render provides DATABASE_URL automatically
DATABASE_URL=postgresql://user:password@localhost/nexus
# For local development, use SQLite:
# DATABASE_URL=sqlite:///./nexus.db

# ── Free API Keys ─────────────────────────────────────────────────────────

# Alpha Vantage (stock data, free tier)
# Get from: https://www.alphavantage.co/
ALPHA_VANTAGE_KEY=demo

# NewsAPI (sentiment analysis)
# Get from: https://newsapi.org (free tier with limits)
NEWS_API_KEY=

# Financial Modeling Prep (fundamentals)
# Get from: https://financialmodelingprep.com
FMP_API_KEY=

# FRED (Federal Reserve Economic Data)
# Get from: https://fred.stlouisfed.org/docs/api
FRED_API_KEY=

# ── Telegram (Alerts) ─────────────────────────────────────────────────────
# Telegram Bot: Message @BotFather and get bot token
# Chat ID: Use @userinfobot to get your Telegram ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────
# Get from: https://www.twilio.com (free trial $15 credit)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=

# ── Cloudflare ────────────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com (free tier)
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_API_TOKEN=

# ── Scheduler ─────────────────────────────────────────────────────────────
POLL_INTERVAL_SEC=60
ML_RETRAIN_HOURS=24
MAX_WORKERS=4

# ── Port (Render uses PORT env var) ───────────────────────────────────────
PORT=8000
